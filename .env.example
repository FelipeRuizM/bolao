# Local dev: copy this file to `.env.development.local` and fill in the
# dev Firebase project's values. `npm run dev` picks that file automatically.
# Production values live only in GitHub Actions secrets (see .github/workflows/deploy.yml).
# `.env*.local` is gitignored.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
